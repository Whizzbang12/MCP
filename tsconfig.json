{
    "compilerOptions": {
        "rootDir": "./src",
        "outDir": "./dist",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "target": "esnext",
        "lib": ["esnext"],
        "types": ["node"],
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
    },
    "include": ["./src"],
}